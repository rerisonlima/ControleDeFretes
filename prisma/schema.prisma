generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  username  String   @unique
  password  String
  role      String   @default("OPERATOR")
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoriaVeiculos {
  id            Int       @id @default(autoincrement())
  CategoriaNome String    @unique
  veiculos      Vehicle[]
  fretes        Frete[]
}

model Contratante {
  id              Int       @id @default(autoincrement())
  ContratanteNome String    @unique
  active          Boolean   @default(true)
  fretes          Frete[]
  trips           Trip[]
}

model Frete {
  id                      Int               @id @default(autoincrement())
  cidade                  String
  contratanteId           Int
  contratante             Contratante       @relation(fields: [contratanteId], references: [id])
  categoriaId             Int
  categoria               CategoriaVeiculos @relation(fields: [categoriaId], references: [id])
  valorFrete              Float
  valor1aViagemMotorista  Float
  valor2aViagemMotorista  Float
  valor1aViagemAjudante   Float
  valor2aViagemAjudante   Float
  validade                DateTime
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  trips                   Trip[]
}

model Vehicle {
  id              Int      @id @default(autoincrement())
  plate           String   @unique
  type            String
  brand           String
  model           String
  year            Int
  capacity        Float
  status          String   @default("ACTIVE")
  lastMaintenance DateTime?
  categoriaId     Int?
  categoria       CategoriaVeiculos? @relation(fields: [categoriaId], references: [id])
  trips           Trip[]
  expenses        Expense[]
  maintenances    Maintenance[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Maintenance {
  id              Int      @id @default(autoincrement())
  type            String
  odometer        Float
  executionDate   DateTime
  vehicleId       Int
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  phone     String?
  pix       String?
  cnh       String?
  cnhCategory String? @db.VarChar(5)
  trips     Trip[]   @relation("DriverTrips")
  helperTrips Trip[] @relation("HelperTrips")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Route {
  id              Int      @id @default(autoincrement())
  destination     String
  freightValue    Float
  driverValue1    Float
  driverValue2    Float
  helperValue1    Float
  helperValue2    Float
  trips           Trip[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Trip {
  id          Int      @id @default(autoincrement())
  tripId      String   @unique
  routeId     Int?
  route       Route?   @relation(fields: [routeId], references: [id])
  freteId     Int?
  frete       Frete?   @relation(fields: [freteId], references: [id])
  contratanteId Int?
  contratante Contratante? @relation(fields: [contratanteId], references: [id])
  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId    Int
  driver      Employee @relation("DriverTrips", fields: [driverId], references: [id])
  helperId    Int?
  helper      Employee? @relation("HelperTrips", fields: [helperId], references: [id])
  scheduledAt DateTime
  value       Float
  valor1aViagemMotorista Float?
  valor2aViagemMotorista Float?
  valor1aViagemAjudante  Float?
  valor2aViagemAjudante  Float?
  status      String   @default("SCHEDULED")
  paid        String   @default("não")
  contract    String?
  romaneio    String?
  odometer    Float?
  paymentDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          Int      @id @default(autoincrement())
  date        DateTime
  type        String
  description String?
  vehicleId   Int?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  value       Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ValoresPagamentoMotoristaAjudante {
  id                        Int      @id @default(autoincrement())
  validade                  DateTime
  destino                   String
  categoria                 String?
  valorPgto1ViagemMotorista Int
  valorPgto2ViagemMotorista Int
  valorPgto1ViagemAjudante  Int
  valorPgto2ViagemAjudante  Int
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
